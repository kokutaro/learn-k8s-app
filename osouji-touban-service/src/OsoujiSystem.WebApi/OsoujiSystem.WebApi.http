@WebApi_HostAddress = https://localhost:7078
@baseUrl = {{WebApi_HostAddress}}

@area_id = d49e41d3-1428-430e-98c8-6df911eae6c4
@spot_id = 22222222-2222-2222-2222-222222222222
@spot2_id = 22222222-3333-3333-3333-333333333333
@user_id = 1cefad64-d1c4-4288-a85d-5687341d4d0d
@to_area_id = 55555555-5555-5555-5555-555555555555
@to_area_member_id = 66666666-6666-6666-6666-666666666666
@plan_id = 07aa9668-7a26-44ea-aaa4-ceecdee63064

# GET の ETag を見て手動で更新してください
@to_area_etag = "1"

# mutation endpoint は ReadModel 可視化待機 timeout 時に 202 Accepted を返すことがあります。
# その場合は `Location`, `Retry-After`, `X-ReadModel-Visibility: pending` を確認し、
# command を再送せず `Location` の GET を再試行してください。

### Health
GET {{baseUrl}}/health
Accept: application/json

### Register user

< {%
    request.variables.set("employeeNumber", $random.integer(100000, 999999).toString());
%}

POST {{baseUrl}}/api/v1/users
Content-Type: application/json
Accept: application/json

{
  "employeeNumber": "{{employeeNumber}}",
  "displayName": "John Doe",
  "emailAddress": "john_doe@example.com",
  "department": "General Affairs",
  "registrationSource": "adminPortal"
}

### Get user
GET {{baseUrl}}/api/v1/users/{{user_id}}
Accept: application/json

> {% client.global.set("user_etag", response.headers.valueOf("ETag")); %}

### Update user profile
PATCH {{baseUrl}}/api/v1/users/{{user_id}}
If-Match: {{user_etag}}
Content-Type: application/json
Accept: application/json

{
  "displayName": "John Doe Updated",
  "emailAddress": "john_updated@example.com",
  "departmentCode": "OPS"
}

### Change user lifecycle
POST {{baseUrl}}/api/v1/users/{{user_id}}/lifecycle
If-Match: {{user_etag}}
Content-Type: application/json
Accept: application/json

{
  "lifecycleStatus": "active"
}

### Link auth identity
POST {{baseUrl}}/api/v1/users/{{user_id}}/identity-links
If-Match: {{user_etag}}
Content-Type: application/json
Accept: application/json

{
  "identityProviderKey": "entra-id",
  "identitySubject": "00000000-0000-0000-0000-000000000123",
  "loginHint": "john_doe@example.com"
}

### Register facility
POST {{baseUrl}}/api/v1/facilities
Content-Type: application/json
Accept: application/json

{
  "facilityCode": "TOKYO-HQ",
  "name": "Tokyo Head Office",
  "description": "Main office building",
  "timeZoneId": "Asia/Tokyo"
}

### Get facility
GET {{baseUrl}}/api/v1/facilities/00000000-0000-0000-0000-000000000001
Accept: application/json

> {% client.global.set("facility_etag", response.headers.valueOf("ETag")); %}

### Update facility
PUT {{baseUrl}}/api/v1/facilities/00000000-0000-0000-0000-000000000001
If-Match: {{facility_etag}}
Content-Type: application/json
Accept: application/json

{
  "name": "Tokyo Head Office Annex",
  "description": "Annex building",
  "timeZoneId": "Asia/Tokyo"
}

### Change facility activation
PUT {{baseUrl}}/api/v1/facilities/00000000-0000-0000-0000-000000000001/activation
If-Match: {{facility_etag}}
Content-Type: application/json
Accept: application/json

{
  "lifecycleStatus": "active"
}

### List cleaning areas
GET {{baseUrl}}/api/v1/cleaning-areas?limit=20&sort=name
Accept: application/json

### Register cleaning area
POST {{baseUrl}}/api/v1/cleaning-areas
Content-Type: application/json
Accept: application/json

{
  "areaId": "{{area_id}}",
  "name": "3F East",
  "initialWeekRule": {
    "startDay": "monday",
    "startTime": "09:00:00",
    "timeZoneId": "Asia/Tokyo",
    "effectiveFromWeek": "2026-W10"
  },
  "initialSpots": [
    {
      "spotId": "{{spot_id}}",
      "spotName": "Pantry",
      "sortOrder": 10
    }
  ]
}

### Pending create example
# 202 Accepted の場合は以下のような body を返します:
# {
#   "data": {
#     "resourceId": "...",
#     "location": "/api/v1/cleaning-areas/...",
#     "readModelStatus": "pending"
#   }
# }

### Get cleaning area
GET {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}
Accept: application/json

> {% client.global.set("area_etag", response.headers.valueOf("ETag")); %}

### Schedule week rule change
PUT {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}/pending-week-rule
If-Match: {{area_etag}}
Content-Type: application/json
Accept: application/json

{
  "startDay": "tuesday",
  "startTime": "08:30:00",
  "timeZoneId": "Asia/Tokyo",
  "effectiveFromWeek": "2026-W12"
}

### Add cleaning spot
< {% 
    request.variables.set("spot2_id", $uuid);
%}
POST {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}/spots
If-Match: {{area_etag}}
Content-Type: application/json
Accept: application/json

{
  "spotId": "{{spot2_id}}",
  "name": "Meeting Room 114",
  "sortOrder": 80
}

### Assign user to area

POST {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}/members
If-Match: {{area_etag}}
Content-Type: application/json
Accept: application/json

{
  "userId": "{{user_id}}"
}

> {% client.global.set("area_etag", response.headers.valueOf("ETag")); %}

### Unassign user from area
DELETE {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}/members/{{user_id}}
If-Match: {{area_etag}}
Accept: application/json

### Remove cleaning spot
DELETE {{baseUrl}}/api/v1/cleaning-areas/{{area_id}}/spots/{{spot2_id}}
If-Match: {{area_etag}}
Accept: application/json

### Register destination area for transfer demo
POST {{baseUrl}}/api/v1/cleaning-areas
Content-Type: application/json
Accept: application/json

{
  "areaId": "{{to_area_id}}",
  "name": "4F West",
  "initialWeekRule": {
    "startDay": "monday",
    "startTime": "09:00:00",
    "timeZoneId": "Asia/Tokyo",
    "effectiveFromWeek": "2026-W10"
  },
  "initialSpots": [
    {
      "spotId": "88888888-8888-8888-8888-888888888888",
      "spotName": "Lobby",
      "sortOrder": 10
    }
  ]
}

### Transfer user to another area
POST {{baseUrl}}/api/v1/area-member-transfers
Content-Type: application/json
Accept: application/json

{
  "fromAreaId": "{{area_id}}",
  "toAreaId": "{{to_area_id}}",
  "userId": "{{user_id}}",
  "toAreaMemberId": "{{to_area_member_id}}",
  "employeeNumber": "123456",
  "fromAreaVersion": 1,
  "toAreaVersion": 1
}

### List weekly duty plans
GET {{baseUrl}}/api/v1/weekly-duty-plans?limit=20&sort=-weekId
Accept: application/json

### Generate weekly duty plan
POST {{baseUrl}}/api/v1/weekly-duty-plans
Content-Type: application/json
Accept: application/json

{
  "areaId": "{{area_id}}",
  "weekId": "2026-W10",
  "policy": {
    "fairnessWindowWeeks": 4
  }
}

### Get weekly duty plan
GET {{baseUrl}}/api/v1/weekly-duty-plans/68dfe61b-d609-47b4-85fd-9b99b80d0fcd
Accept: application/json

> {% client.global.set("plan_etag", response.headers.valueOf("ETag")); %}

### Publish weekly duty plan
PUT {{baseUrl}}/api/v1/weekly-duty-plans/68dfe61b-d609-47b4-85fd-9b99b80d0fcd/publication
If-Match: {{plan_etag}}
Accept: application/json

### Close weekly duty plan
PUT {{baseUrl}}/api/v1/weekly-duty-plans/0654f1e8-1a66-4cac-9ed1-12fd06587864/closure
If-Match: {{plan_etag}}
Accept: application/json

### Apply due week rule changes
POST {{baseUrl}}/api/v1/internal/week-rule-applications
Content-Type: application/json
Accept: application/json

{
  "currentWeek": "2026-W10"
}

### Generate current week plans batch
POST {{baseUrl}}/api/v1/internal/current-week-plan-generations
Content-Type: application/json
Accept: application/json

{
  "policy": {
    "fairnessWindowWeeks": 4
  }
}
