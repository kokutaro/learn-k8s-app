{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "osouji-db": "",
    "osouji-redis": "",
    "osouji-rabbitmq": ""
  },
  "Infrastructure": {
    "PersistenceMode": "EventStore",
    "Postgres": {
      "Schema": "public",
      "CommandTimeoutSeconds": 30
    },
    "Redis": {
      "DefaultTtlSeconds": 300
    },
    "RabbitMq": {},
    "Outbox": {
      "BatchSize": 100,
      "PollIntervalMs": 1000
    },
    "Projection": {
      "BatchSize": 200,
      "PollIntervalMs": 1000
    },
    "ProjectionVisibility": {
      "Enabled": true,
      "WaitTimeoutMs": 3000,
      "PollIntervalMs": 50
    },
    "Retention": {
      "DailyRunJst": "03:30",
      "EventStoreYears": 7,
      "OutboxPublishedDays": 180,
      "OutboxFailedDays": 365,
      "DlqDays": 30,
      "LogDays": 180,
      "TraceDays": 14,
      "MetricsMonths": 13
    },
    "Pii": {
      "TenantSaltSecretName": "osouji-pii-salt",
      "MaskEmployeeNumber": true
    },
    "AutoScheduler": {
      "Enabled": true,
      "PollIntervalSeconds": 60
    }
  },
  "AllowedHosts": "*"
}
